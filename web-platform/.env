# OCR Platform - Docker Environment Configuration
# This file contains Docker-specific environment variables
# Copy to .env and customize for your deployment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_PASSWORD=secure_dev_password_123
DATABASE_URL=postgresql://ocr_user:secure_dev_password_123@postgres:5432/ocr_platform

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
WORKER_CONCURRENCY=2

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
ENCRYPTION_SECRET=dev-encryption-secret-change-in-production-minimum-32-chars

# =============================================================================
# MONITORING CONFIGURATION (Optional)
# =============================================================================
# Redis Commander credentials (for queue monitoring)
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin123

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# For production deployment, update these values:
# 
# POSTGRES_PASSWORD=your-super-secure-database-password
# ENCRYPTION_SECRET=your-secure-encryption-key

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# - All services run in containers with Docker networking
# - Database URL uses container name 'postgres' instead of localhost
# - Redis host uses container name 'redis' instead of localhost
# - File uploads are persisted in Docker volumes
# - Logs are stored in shared Docker volumes
# - No local Python/PostgreSQL/Redis installation required
# - No authentication required - direct access to OCR functionality