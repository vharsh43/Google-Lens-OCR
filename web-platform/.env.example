# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/ocr_platform"

# Redis Configuration (for job queue)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""  # Leave empty if no password

# File Upload Configuration
UPLOAD_DIR="./uploads"
# MAX_FILE_SIZE - Remove or set very high for unlimited file processing
# MAX_FILE_SIZE="10737418240"  # 10GB - uncomment to set a limit

# OCR Processing Configuration
# PYTHON_PATH - Leave empty for auto-detection, or specify path (python3, python, py, or full path)
PYTHON_PATH=""
PDF_SCRIPT_PATH="../PDF_2_PNG.py"
OCR_SCRIPT_PATH="../src/batch-process.js"
OCR_LOGS_DIR="../logs"

# Worker Configuration
WORKER_CONCURRENCY="2"  # Number of concurrent OCR jobs

# Application Configuration
NODE_ENV="development"  # development, production, test
PORT="3333"  # Fixed port to avoid conflicts


# Rate Limiting (optional)
# RATE_LIMIT_REQUESTS="100"
# RATE_LIMIT_WINDOW="3600"  # 1 hour in seconds

# Monitoring (optional)
# SENTRY_DSN="your-sentry-dsn"
# ANALYTICS_ID="your-analytics-id"

# Email Configuration (optional, for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-email-password"
# FROM_EMAIL="noreply@yourapp.com"