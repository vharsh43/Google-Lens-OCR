# OCR Web Platform - Development Dockerfile
# Optimized for development with hot reloading and debugging
# Includes complete OCR processing pipeline support

FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install system dependencies including build tools for PyMuPDF
RUN apk update && apk add --no-cache \
    python3 \
    py3-pip \
    curl \
    bash \
    gcc \
    musl-dev \
    python3-dev

# Install PyMuPDF (required for PDF to PNG conversion)
RUN pip3 install --break-system-packages --no-cache-dir PyMuPDF tqdm || \
    (echo "PyMuPDF installation failed" && exit 1)

# Copy package files first for better caching
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm ci --only=production=false && npm cache clean --force

# Copy Prisma schema and generate client
COPY prisma ./prisma/
RUN npx prisma generate

# Create necessary directories with proper permissions
RUN mkdir -p /app/uploads /app/logs /app/processed /app/scripts /app/scripts/src

# Create non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 --ingroup nodejs nextjs

# Copy application code
COPY --chown=nextjs:nodejs . .

# Ensure scripts directory exists and is accessible
RUN chown -R nextjs:nodejs /app && \
    chmod +x /app/scripts/* 2>/dev/null || true

# Make Python scripts executable
RUN find /app/scripts -name "*.py" -exec chmod +x {} \; 2>/dev/null || true

# Switch to non-root user
USER nextjs

# Expose the port the app runs on
EXPOSE 3333

# Set environment variables
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3333
ENV HOSTNAME="0.0.0.0"
ENV PYTHON_PATH=/usr/bin/python3

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:3333/api/health || exit 1

# Default command (can be overridden by docker-compose)
CMD ["npm", "run", "dev"]